import math
import requests

def motor_srm_live(api_key, query):
    # 1. Colectăm date reale prin NewsAPI
    #
    url = f"https://newsapi.org/v2/everything?q={query}&apiKey={api_key}"
    response = requests.get(url).json()
    
    articles = response.get('articles', [])
    total_results = response.get('totalResults', 0)
    
    # 2. Calculăm variabilele SRM conform modelului tău v1.1
    #
    
    # N (Network Reach) - bazat pe diversitatea surselor media
    surse_unice = len(set([a['source']['name'] for a in articles]))
    N = min(surse_unice / 20, 1.0) 
    
    # V (Velocity) - bazat pe volumul de știri găsite
    V = min(total_results / 100, 1.0)
    
    # Valori teoretice pentru A și Drift (vor fi automatizate ulterior)
    #
    A = 0.7  # Affective Weight
    D = 0.1  # Semantic Drift
    lam = 0.5
    
    # 3. Formula SRM: V * A * e^(-lambda * D) * N
    #
    scor = V * A * math.exp(-lam * D) * N
    
    # Clasificarea stării politice
    if scor >= 0.8: stare = "HEGEMONIC RESONANCE"
    elif scor >= 0.5: stare = "ACTIVE RESONANCE"
    elif scor >= 0.2: stare = "MARGINAL SIGNAL"
    else: stare = "SYMBOLIC EXTINCTION"
    
    return round(scor, 4), stare

